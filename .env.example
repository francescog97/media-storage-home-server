# Timezone used by Jellyfin and Uptime Kuma
TZ=Europe/Rome

# This path must exist on the i5 notebook and should point to the NAS media share
MEDIA_PATH=/mnt/nas/media

# URL advertised by Jellyfin to clients on your LAN
JELLYFIN_PUBLISHED_URL=http://192.168.1.50:8096

# Tailscale node name for the i5 notebook
TAILSCALE_HOSTNAME=asus-i5-media

# Generate this from the Tailscale admin console
TS_AUTHKEY=tskey-auth-change-me
